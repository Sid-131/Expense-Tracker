# ─────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# NEVER commit .env to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────

# ── 1. PostgreSQL password ────────────────────────────────
# Any strong password you invent. Used only internally
# between Docker containers — never exposed to the internet.
# Generate one:  openssl rand -base64 32
DB_PASSWORD=change_me_strong_password

# ── 2. JWT signing secret ─────────────────────────────────
# Random string used to sign all JWT tokens.
# Generate one:  openssl rand -hex 32
JWT_SECRET=change_me_long_random_secret

# ── 3. Google OAuth Web Client ID ────────────────────────
# Needed for "Sign in with Google" on Android.
# How to get it:
#   Option A (Firebase — recommended):
#     1. Go to https://console.firebase.google.com
#     2. Create project → Add Android app (package: com.expensio)
#     3. Authentication → Sign-in method → Enable Google
#     4. Web SDK configuration → copy "Web client ID"
#   Option B (Google Cloud Console):
#     1. Go to https://console.cloud.google.com/apis/credentials
#     2. Create OAuth 2.0 Client ID → Web application
#     3. Copy the Client ID
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── 4. Debug mode ─────────────────────────────────────────
# true  = verbose logs + auto-reload (use on server during dev)
# false = silent logs, no reload (use in production)
DEBUG=false
